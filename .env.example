# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env.tst or .env.uat and fill in real values.
# Never commit files containing real credentials to source control.
# In the ADO pipeline, these values come from the pipeline variable library.
# ─────────────────────────────────────────────────────────────────────────────

# Application URLs
BASE_URL=https://your-app.example.com
LOGIN_URL=https://your-app.example.com/Security/Login.asp

# Admin credentials
ADMIN_USERNAME=your_username
ADMIN_PASSWORD=your_password

# Timeouts (milliseconds)
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000
ELEMENT_TIMEOUT=15000

# Microsoft SQL Server — Database connection
DB_SERVER=your-db-server.example.com
DB_NAME=your_database_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true
