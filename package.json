{
  "name": "playwright-framework-template",
  "version": "1.0.0",
  "description": "Robust Playwright + TypeScript test automation framework with POM, Allure reporting, MSSQL and multi-environment support",
  "scripts": {
    "test": "playwright test",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:parallel": "playwright test --workers=4",
    "test:tst": "cross-env TEST_ENV=tst playwright test",
    "test:uat": "cross-env TEST_ENV=uat playwright test",
    "test:prod": "cross-env TEST_ENV=prod playwright test",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "report": "node scripts/show-report.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "mssql": "^10.0.4",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.1",
    "@types/mssql": "^9.1.4",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "allure-commandline": "^2.29.0",
    "allure-playwright": "^2.14.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
